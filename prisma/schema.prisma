generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PageContent {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  content     String?
  contentJson Json?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
}
